# Cloud Vibe 部署配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# 服务器配置（必需）
DEPLOY_HOST=192.168.1.100
DEPLOY_USER=ubuntu

# 认证方式（二选一）
# 方式 1: 使用密码
DEPLOY_PASSWORD=your_password_here

# 方式 2: 使用 SSH 密钥（更安全）
# DEPLOY_SSH_KEY=~/.ssh/id_rsa

# 部署路径（可选，默认: /var/www/cloud-vibe）
DEPLOY_PATH=/var/www/cloud-vibe

# 应用域名（可选，用于显示）
DEPLOY_DOMAIN=vibe.iamxmm.xyz
